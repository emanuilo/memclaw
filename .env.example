# Required for embeddings and image descriptions
OPENAI_API_KEY=your-openai-key

# Required for the Claude agent (interactive mode + /ask command)
ANTHROPIC_API_KEY=your-anthropic-key

# Telegram bot settings
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
ALLOWED_USER_IDS=123456789,987654321

# WhatsApp bot (personal account via WhatsApp Web — QR pairing)
# Leave blank to only accept messages from your own paired account
# (self-notes). Add numbers here to let others DM the bot.
WHATSAPP_ALLOWED_NUMBERS=+1234567890,+0987654321
